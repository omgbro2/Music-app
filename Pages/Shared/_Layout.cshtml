<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication2</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication2.styles.css" asp-append-version="true" />
</head>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<body class="app-bg">

    <div class="flex-grow-1">

        <!-- 🔝 TOP BAR -->
        <div class="d-flex justify-content-between align-items-center p-3"
             style="background: rgba(0,0,0,0.2);">

            <!-- ✅ MĀJAS POGA (Kreisajā pusē) -->
            <div>
                <a asp-page="/Playlists/Index" class="btn btn-dark">
                    Home
                </a>
            </div>

            <!-- Profile Dropdown (Labajā pusē) -->
            <div class="dropdown">

                <button class="btn btn-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    👤 Profile
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a class="dropdown-item" href="/Account/Profile">My Profile</a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="/Account/Logout">Logout</a>
                    </li>
                </ul>

            </div>

        </div>

        <!-- PAGE CONTENT -->
        <div class="p-4">
            @RenderBody()
        </div>

    </div>

</body>

</html>
