@page "{id:int}"
@model WebApplication2.Pages.Playlists.DetailsModel

<h2>@Model.PlaylistName</h2>

<hr />

<h4>Add Song</h4>

<form method="post" asp-page-handler="AddSong" asp-route-id="@Model.PlaylistId">
    <input type="hidden" asp-for="PlaylistId" />

    <input asp-for="Title" placeholder="Title" />
    <input asp-for="Artist" placeholder="Artist" />
    <input asp-for="Duration" type="number" placeholder="Duration (seconds)" />

    <button type="submit" class="btn btn-success">Add</button>
</form>

<hr />

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Artist</th>
            <th>Duration</th>
            <th>Date Added</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var song in Model.Songs)
        {
            <tr>
                <td>@song.Title</td>
                <td>@song.Artist</td>
                <td>
                    @String.Format("{0}:{1:D2}", song.Duration / 60, song.Duration % 60)
                </td>
                <td>@song.DateAdded</td>
            </tr>
        }
    </tbody>
</table>