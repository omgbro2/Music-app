@page
@model WebApplication2.Pages.Playlists.IndexModel
@{
    ViewData["Title"] = "My Playlists";
}

<h2>Hello, @Model.Username</h2>

<!-- CREATE NEW PLAYLIST -->
<form method="post" asp-page-handler="Create">
    <input asp-for="NewPlaylistName" placeholder="New playlist name" />
    <button type="submit">Create Playlist</button>
</form>

<hr />

<!-- LIST OF PLAYLISTS -->
<ul>
    @foreach (var playlist in Model.Playlists)
    {
        <li>
            <a asp-page="/Playlists/Details" asp-route-id="@playlist.Id">
                @playlist.Name
            </a>
        </li>
    }
</ul>