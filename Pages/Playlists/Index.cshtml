@page
@model WebApplication2.Pages.Playlists.IndexModel

<div class="container-fluid">
    <div class="row">

        <!-- 📱 KREISĀ PUSE: Sidebar (Playlistu saraksts) -->
        <div class="col-md-3 border-end min-vh-100 p-3" style="background: rgba(0,0,0,0.1);">
            <h4 class="mb-3">MY PLAYLISTS</h4>

            <!-- CREATE FORM: posts to IndexModel.OnPostAsync -->
            <form method="post" class="mb-3">
                <div class="input-group">
                    <input asp-for="PlaylistName" class="form-control form-control-sm bg-dark text-white" placeholder="+ Create new playlist..." required />
                    <button class="btn btn-outline-light" type="submit">Create</button>
                </div>
            </form>

            <!-- Search & Sort -->
            <div class="input-group mb-2">
                <input type="text" class="form-control form-control-sm bg-dark text-white" placeholder="Search for playlist...">
            </div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <small class="text-muted">Sort</small>
                <button class="btn btn-sm btn-link text-white p-0">≡</button>
            </div>

            <!-- Playlistu pogas -->
            <div class="list-group">
                @foreach (var playlist in Model.Playlists)
                {
                    <div class="d-flex align-items-center mb-2 bg-dark-subtle rounded-3"
                         style="background: rgba(255,255,255,0.05) !important; border-radius: 10px; transition: 0.3s;">

                        <!-- Galvenā saite (Playlist atvēršanai) -->
                        <a asp-page="/Playlists/Index" asp-route-id="@playlist.Id"
                           class="text-white border-0 d-flex align-items-center p-2 flex-grow-1 text-decoration-none">
                            <div class="me-3 p-2 bg-purple rounded" style="background: #a855f7;">🎵</div>
                            <div>
                                <div class="fw-bold">@playlist.Name</div>
                                <small class="text-muted">@((playlist.Songs?.Count) ?? 0) elements</small>
                            </div>
                        </a>

                        <!-- DZĒŠANAS FORMA (Miskastes poga) -->
                        <form method="post" asp-page-handler="DeletePlaylist"
                              onsubmit="return confirm('Dzēst @playlist.Name?');" class="pe-2">
                            <input type="hidden" name="id" value="@playlist.Id" />
                            <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none shadow-none p-0">
                                <small>🗑️</small>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- 🎵 LABĀ PUSE: Aktīvā Playlist (Saturs) -->
        <div class="col-md-9 p-4">

            @* Use the selected playlist provided by the PageModel *@
            @if (Model.CurrentPlaylist != null)
            {
                <div class="d-flex align-items-center mb-4">
                    <div class="p-4 bg-purple rounded me-4" style="background: #a855f7; font-size: 2rem;">🎵</div>
                    <div>
                        @* <a asp-page="/Playlists/Edit" asp-route-id="@playlist.Id" class="btn btn-warning btn-sm">Edit</a> *@
                        <h1 class="display-5 fw-bold">@Model.CurrentPlaylist.Name <a href="/Playlists/Edit/@Model.CurrentPlaylist.Id"><small>✏</small></a></h1>
                        <p class="text-muted">@((Model.CurrentPlaylist.Songs?.Count) ?? 0) elements • Created: @DateTime.Now.ToShortDateString()</p>
                    </div>
                </div>

                <!-- ADD SONG FORM (Kā tavā zīmējumā) -->
                <div class="card bg-dark text-white p-4 mb-4 shadow" style="max-width: 500px; border-radius: 15px;">
                    <h5 class="mb-3">ADD NEW SONG</h5>
                    <form method="post" asp-page-handler="AddSong" enctype="multipart/form-data">
                        <input type="hidden" asp-for="TargetPlaylistId" value="@Model.CurrentPlaylist.Id" />

                        <div class="mb-2">
                            <label class="small text-muted">Title</label>
                            <input asp-for="SongTitle" class="form-control bg-secondary text-white border-0" placeholder="Title" required />
                        </div>
                        <div class="mb-2">
                            <label class="small text-muted">Artist</label>
                            <input asp-for="SongArtist" class="form-control bg-secondary text-white border-0" placeholder="Artist" required />
                        </div>
                        <div class="row g-2 mb-3">
                            <input type="file" asp-for="FileUpload" id="file" name="file" /><!-- file upload -->
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill" style="background: #a855f7; border: 0;">Add</button>
                    </form>
                </div>

                <!-- DZIESMU TABULA -->
                <table class="table table-dark table-hover align-middle">
                    <thead class="text-muted">
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Artist</th>
                            <th>Date added</th>
                            <th>Duration</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.CurrentPlaylist.Songs != null && Model.CurrentPlaylist.Songs.Any())
                        {
                            int counter = 1;
                            @foreach (var song in Model.CurrentPlaylist.Songs)
                            {
                                <tr>
                                    @* Use a form for each row so we can submit the update *@
                                    <form method="post" asp-page-handler="UpdateSong">
                                        <input type="hidden" name="songId" value="@song.Id" />
                                        <input type="hidden" name="playlistId" value="@Model.CurrentPlaylist.Id" />

                                        <td>@counter</td>
                                        <td>
                                            <input name="updatedTitle" value="@song.Title" 
                                                   class="form-control form-control-sm bg-dark text-white border-0" />
                                        </td>
                                        <td>
                                            <input name="updatedArtist" value="@song.Artist" 
                                                   class="form-control form-control-sm bg-dark text-white border-0" />
                                        </td>
                                    <td>@song.DateAdded.ToShortDateString()</td>@*TO DO make this display correct added time not just today *@
                                        
                                        <td>
                                            <div class="d-flex gap-1">
                                                <input name="updatedMinutes" value="@(song.Duration / 60)" 
                                                       type="number" class="form-control form-control-sm bg-dark text-white border-0" style="width: 50px;" />
                                                <span class="text-muted">:</span>
                                                <input name="updatedSeconds" value="@(song.Duration % 60)" 
                                                       type="number" class="form-control form-control-sm bg-dark text-white border-0" style="width: 50px;" />
                                            </div>
                                        </td>

                                        <td class="text-end">
                                            @* Save Button *@
                                            <button type="submit" class="btn btn-sm btn-link text-success p-0 me-2" title="Save">💾</button>
                        
                                            @* Delete Button (Keep your existing one) *@
                                            <button type="submit" asp-page-handler="DeleteSong" 
                                                    class="btn btn-sm btn-link text-danger p-0" 
                                                    onclick="return confirm('Delete?');">🗑️</button>
                                        </td>
                                    </form>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>

                </table>
            }
            else
            {
                <div class="text-center mt-5">
                    <h3>Select a playlist from the left to view details</h3>
                </div>
            }
        </div>
    </div>
</div>
