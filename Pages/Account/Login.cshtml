@page
@model WebApplication2.Pages.Account.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card-dark text-center" style="width: 350px; padding: 2rem; border-radius: 15px; background: #1a1a1a; box-shadow: 0 8px 32px rgba(0,0,0,0.5);">
        
        <h3 class="mb-4 text-white">EXISTING USER</h3>

        <form method="post" asp-page-handler="Login">
            <input asp-for="Login.UserName" class="form-control mb-2 bg-white text-dark" placeholder="Username" required />
            <input asp-for="Login.Password" class="form-control mb-3 bg-white text-dark" type="password" placeholder="Password" required />

            <button type="submit" class="btn-purple w-100 mb-3" style="background: linear-gradient(90deg, #d946ef, #a855f7); border: none; color: white; padding: 10px; border-radius: 20px;">Log in</button>
        </form>

        @* Moved Error Message inside the card so it stays centered *@
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger p-2 mb-3" style="font-size: 0.8rem;">
                @Model.ErrorMessage
            </div>
        }

        @* Moved Register link here *@
        <p class="text-white-50 small mt-2">
            Don't have an account? 
            <a asp-page="/Account/Register" class="text-info text-decoration-none">Register here</a>
        </p>

    </div>
</div>
