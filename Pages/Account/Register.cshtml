@page
@model WebApplication2.Pages.Account.RegisterModel
@{
}



<h2>Sign Up</h2>

<form method="post" asp-page-handler="Register">
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="card-dark text-center" style="width: 350px;">
            <h3 class="mb-3">NEW USER</h3>

            <input asp-for="Register.UserName" class="form-control mb-2" placeholder="Username" />
            <input asp-for="Register.Password" class="form-control mb-2" type="password" placeholder="Password" />
            <input asp-for="Register.ConfirmPassword" class="form-control mb-3" type="password" placeholder="Confirm password" />

            <button class="btn-purple w-100">Create</button>
        </div>
    </div>

    @* <button type="submit">Sign Up</button> *@
</form>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <p style="color:red">@Model.ErrorMessage</p>
}