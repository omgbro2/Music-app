@page
@model ProfileModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<WebApplication2.Models.User> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    if (user == null)
    {
        Response.Redirect("/Account/Login");
    }
}



<h2>User Profile</h2>

<div class="card-dark d-flex align-items-center">

    <img src="/images/default-user.png"
         style="width:100px; border-radius:50%; margin-right:20px;" />

    <div>
        <h2>{user}</h2>
        <p>Hello 👋</p>

        <p><b>About:</b> ...</p>
        <p>Account created: DD/MM/YYYY</p>
    </div>
    <form method="post">
        <div><strong>Username:</strong> @user?.UserName</div>
        <div>
            <label asp-for="UsernameData.DisplayName"></label>
            <input asp-for="UsernameData.DisplayName" value="@user?.UserName" />
            <span asp-validation-for="UsernameData.DisplayName"></span>
        </div>
        <button type="submit">Update Profile</button>
    </form>
</div>

<a asp-page="/Index">Back to Home</a>

