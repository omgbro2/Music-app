@page
@model ProfileModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<WebApplication2.Models.User> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<h2>User Profile</h2>

<div class="card-dark d-flex align-items-center p-4" style="background: rgba(255,255,255,0.05); border-radius: 15px;">

    <img src="/images/default-user.png" style="width:100px; border-radius:50%; margin-right:20px;" />

 <div class="flex-grow-1">
    <h2 class="fw-bold">@Model.UsernameData.DisplayName</h2>
    <p>Hello 👋</p>

    @* Šeit mēs rādām to, kas ir ielādēts OnGetAsync *@
    <p><b>About:</b> @Model.UsernameData.AboutMe</p>
    
    @{
        var curUser = await UserManager.GetUserAsync(User);
    }
    <p class="text-muted">Account created: @curUser?.DateCreated.ToString("dd/MM/yyyy")</p>
</div>


    <form method="post" class="ms-4">
        <div class="mb-2">
            <label>Username</label>
            <input asp-for="UsernameData.DisplayName" class="form-control bg-dark text-white" />
        </div>
        <div class="mb-2">
            <label>About Me</label>
            @* Ensure this matches the property in your UserInput class *@
            <textarea asp-for="UsernameData.AboutMe" class="form-control bg-dark text-white"></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">Update Profile</button>
    </form>
</div>

<a asp-page="/Index" class="btn btn-link mt-3">Back to Home</a>
