@page
@model WebApplication2.Pages.IndexModel

<div class="d-flex">

    <!-- Sidebar -->
    <div style="width:250px; background:#1e1e2f; color:white; padding:20px;">
        <h4>MY PLAYLISTS</h4>

        <a class="btn btn-sm btn-primary mb-2" asp-page="/Playlists/Create">+ Create</a>

        <ul class="list-group">
            @foreach (var playlist in Model.Playlists)
            {
                <li class="list-group-item">
                    <a asp-page="/Playlists/Details" asp-route-id="@playlist.Id">
                        @playlist.Name
                        

                    </a>

                    
                </li>
            }
        </ul>
        <a asp-page="/Account/Logout" class="btn btn-danger btn-sm">Logout</a>
        </a.
    </div>

    <!-- Main Content -->
    <div class="flex-fill p-4">
        <h3>Hello, @Model.Username 👋</h3>
        <p>Select a playlist to view songs.</p>
    </div>

</div>
